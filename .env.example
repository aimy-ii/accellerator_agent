# ─── API акселератора ─────────────────────────────────────────────────────────
# БЕЗ /api на конце — префикс добавляет клиент.
API_BASE_URL=http://localhost:8000
API_TIMEOUT=30
API_VERIFY_SSL=false

# Токен заказчика ТОЛЬКО для локальной отладки в Studio.
# В проде токен приходит в context (configurable.user_token) на каждый запрос.
DEV_USER_TOKEN=

# ─── Аутентификация агента (introspection-ручка акселератора) ────────────────
# Ручка интроспекции пользовательского JWT (POST {token, agent_name}).
AGENT_INTROSPECT_URL=http://localhost:8000/api/internal/auth/introspect
# s2s-токен агента — заголовок X-Service-Token. В проде обязателен.
AGENT_INTROSPECT_TOKEN=changeme-agent-introspect-token
# Имя агента, которое шлём в ручку (маппинг AGENT_ROLES на бэкенде).
AGENT_NAME=customer_agent
# Рубильник. false — только локальная отладка (auth пропускается).
AUTH_ENABLED=true

# ─── LLM (OpenAI-совместимый протокол: kodik_router / OpenRouter / локальная) ─
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4.6
LLM_TEMPERATURE=0.2
LLM_MAX_CONCURRENCY=3

# ─── Прокси для LLM (если нужен) ──────────────────────────────────────────────
IS_PROXY=false
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=
# PROXY_SCHEME=socks5h

# ─── Сбор требований (чтобы не утомлять заказчика) ────────────────────────────
QUESTIONS_PER_TURN=3
MIN_QUESTION_ROUNDS=1
RICH_INFO_THRESHOLD=6

# ─── Подбор команды ───────────────────────────────────────────────────────────
CANDIDATES_PER_ROLE=3
CANDIDATES_POOL_SIZE=30

# ─── Презентация: off | local | gamma ─────────────────────────────────────────
PRESENTATION_PROVIDER=off
GAMMA_API_KEY=
GAMMA_BASE_URL=https://public-api.gamma.app/v1.0
GAMMA_EXPORT_AS=pptx
GAMMA_POLL_INTERVAL=5
GAMMA_POLL_TIMEOUT=180

# ─── LangSmith (трейсинг) ─────────────────────────────────────────────────────
LANGSMITH_PROJECT=accelerator-agent
LANGSMITH_API_KEY=
